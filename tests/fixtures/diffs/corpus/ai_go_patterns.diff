+"""API client module for external service communication."""
+
+import logging
+from typing import Optional, Any
+
+# Set up the logger for this module
+logger = logging.getLogger(__name__)
+
+
+class ApiClient:
+    """Client for communicating with the external API service."""
+
+    def __init__(self, base_url: str, api_key: str):
+        """Initialize the API client.
+
+        Args:
+            base_url: The base URL of the API service.
+            api_key: The API key for authentication.
+        """
+        self.base_url = base_url
+        self.api_key = api_key
+
+    def fetch_resource(self, resource_id: str) -> tuple[Optional[dict], Optional[str]]:
+        """Fetch a resource from the API.
+
+        Returns:
+            A tuple of (data, error) where error is None on success.
+        """
+        # Validate the resource ID
+        if resource_id is None:
+            return None, "resource_id is required"
+
+        response, err = self._make_request("GET", f"/resources/{resource_id}")
+        if err is not None:
+            logger.error(f"Failed to fetch resource: {err}")
+            return None, err
+
+        return response, None
+
+    def create_resource(self, data: dict) -> tuple[Optional[dict], Optional[str]]:
+        """Create a new resource via the API.
+
+        Returns:
+            A tuple of (created_resource, error).
+        """
+        # Validate the input data
+        if data is None:
+            return None, "data is required"
+
+        result, err = self._make_request("POST", "/resources", body=data)
+        if err is not None:
+            return None, err
+
+        return result, None
+
+    def _make_request(self, method: str, path: str, body: Any = None) -> tuple[Optional[dict], Optional[str]]:
+        """Make an HTTP request to the API.
+
+        Returns:
+            A tuple of (response_data, error_message).
+        """
+        try:
+            # Build the full URL
+            url = f"{self.base_url}{path}"
+            # Make the request
+            response = self._session.request(method, url, json=body)
+            # Check if the response is successful
+            if response.status_code != 200:
+                return None, f"request failed with status {response.status_code}"
+            return response.json(), None
+        except Exception as e:
+            return None, str(e)
